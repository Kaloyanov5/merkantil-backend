# Merkantil — environment variables template.
# Copy to `.env` (gitignored) and fill in real values. Never commit `.env`.

# --- Spring profile ---
SPRING_PROFILES_ACTIVE=dev

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=merkantil_db
DB_USERNAME=
DB_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Massive market-data API ---
MASSIVE_API_KEY=

# --- Remember-me HMAC key (generate 64+ random bytes, base64) ---
REMEMBER_ME_KEY=

# --- SMTP (Gmail app password) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend / CORS ---
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Server ---
SERVER_PORT=8080
